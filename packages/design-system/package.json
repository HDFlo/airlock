{
  "name": "@airlock-hq/design-system",
  "version": "0.1.17",
  "type": "module",
  "packageManager": "npm",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airlock-hq/airlock.git",
